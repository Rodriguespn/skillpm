# Copy to .env and fill in your values.
# For local dev these are provided automatically by `supabase start`.

# Supabase project URL (e.g. https://xyzabc.supabase.co)
SUPABASE_URL=http://localhost:54321

# Supabase anon key — used by the registry function for public reads
SUPABASE_ANON_KEY=

# Supabase service role key — used by the publish function for authenticated writes
SUPABASE_SERVICE_ROLE_KEY=

# The token the CLI sends when publishing (set this to your service role key)
SKILLPM_TOKEN=

# CLI: registry base URL (can also go in ~/.skillpmrc)
SKILLPM_REGISTRY=http://localhost:54321/functions/v1/registry
